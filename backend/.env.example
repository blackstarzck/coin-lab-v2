COIN_LAB_APP_ENV=development
COIN_LAB_LOG_LEVEL=INFO
COIN_LAB_ALLOWED_ORIGINS=["http://localhost:5173"]

# Store backend: "memory" (dev) or "postgres" (production)
COIN_LAB_STORE_BACKEND=memory

# Postgres / Supabase
# Required when STORE_BACKEND=postgres: use your Supabase Postgres connection string here.
# COIN_LAB_DATABASE_URL=postgresql://user:password@localhost:5432/coinlab
# Optional for REST/API diagnostics or future server-side Supabase usage.
# COIN_LAB_SUPABASE_URL=https://your-project.supabase.co
# COIN_LAB_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# COIN_LAB_SUPABASE_SECRET_KEY=your-secret-key

# Upbit API
COIN_LAB_UPBIT_REST_BASE_URL=https://api.upbit.com
COIN_LAB_UPBIT_WS_PUBLIC_URL=wss://api.upbit.com/websocket/v1
COIN_LAB_UPBIT_WS_PRIVATE_URL=wss://api.upbit.com/websocket/v1/private
# COIN_LAB_UPBIT_ACCESS_KEY=
# COIN_LAB_UPBIT_SECRET_KEY=

# LIVE mode guards (all must be satisfied)
# COIN_LAB_LIVE_TRADING_ENABLED=false
# COIN_LAB_LIVE_REQUIRE_ORDER_TEST=true
# COIN_LAB_LIVE_ORDER_NOTIONAL_KRW=5000
